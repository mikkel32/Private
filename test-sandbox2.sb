(version 1)
(deny default)
(allow process*)
(allow sysctl-read)
(allow mach-lookup)
(allow signal)
(allow file-read-data
    (subpath "/System/Library")
    (subpath "/usr")
    (subpath "/opt/homebrew")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy")
    (subpath "/private/var")
    (subpath "/private/tmp")
    (subpath "/dev")
)
(allow file-read-metadata)
(allow file-write* 
    (subpath "/private/tmp")
    (subpath "/private/var/folders")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/__pycache__")
    (literal "/dev/null")
    (literal "/dev/random")
)
(allow network-inbound)
(allow network-bind)
(deny network-outbound (remote unix-socket))
