(version 1)
(deny default)

; ==============================================================================
; PROJECT MONOLITH - macOS App Sandbox Profile (sandbox-exec)
; Target: Python Inference Engine (llama.cpp / FastAPI)
; ==============================================================================
; MITIGATION: Agentic Autonomy, Remote Code Execution (RCE), Data Exfiltration.
; 
; This strict policy enforces absolute isolation on the LLM instance to ensure
; a hijacked RAG or Prompt-Injection attack cannot compromise the host OS.
; It utilizes a STRICT DEFAULT-DENY model, effectively blocking all files,
; memory mapping, IPC, and network capabilities not overtly permitted.
; ==============================================================================

; --- CORE OS FUNCTIONALITY ---
(allow process-exec*)
(allow process-fork)
(allow sysctl-read)
(allow mach-lookup)
(allow signal)

; --- NETWORK ISOLATION ---
; Deny ALL outbound network connections to prevent exfiltration and C&C callbacks.
; (Deny default implicitly blocks this, but explicitly stated for semantic integrity)
(deny network-outbound (remote tcp))
(deny network-outbound (remote udp))
(deny network-outbound (remote ip))

; Explicit block of UNIX sockets to prevent mDNSResponder & syslog exfiltration
(deny network-outbound (remote unix-socket))

; Explicitly allow localhost bindings so the UI can communicate with the inference node
(allow network-inbound (local ip "127.0.0.1:*"))
(allow network-bind (local ip "127.0.0.1:*"))

; --- FILE SYSTEM ISOLATION ---
(allow file-read-metadata) ; Needed for python to resolve stat() and dtags

; Whitelisted READ access (Strict Minimum for Python & Metal Execution)
(allow file-read-data
    (subpath "/System/Library/Frameworks")
    (subpath "/System/Library/PrivateFrameworks")
    (subpath "/usr/lib")
    (subpath "/usr/share/zoneinfo")
    (subpath "/opt/homebrew/opt/python@3.13")
    (subpath "/opt/homebrew/Cellar/python@3.13")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/.venv")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/server.py")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/image_renderer.py")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/secure_memory.py")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/sep_crypto")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/gemma-4-E4B-it-heretic-Q5_K_M.gguf")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/node_modules/llama-cpp-python")
    (subpath "/Users/mikkelmynderup/Library/Caches")
    (subpath "/private/var/folders")
    (subpath "/private/tmp")
    (subpath "/dev/urandom")
    (subpath "/dev/random")
    (subpath "/dev/null")
)

; Allow writing ONLY to essential transient locations required by Python & macOS Metal.
(allow file-write* 
    (subpath "/private/tmp")
    (subpath "/private/var/folders")
    (subpath "/Users/mikkelmynderup/Desktop/Privacy/Private/__pycache__")
    (literal "/dev/null")
    (literal "/dev/random")
    (literal "/dev/urandom")
)

; --- EXPLICIT DATA THEFT ISOLATION ---
; Even though default deny blocks this, we add explicit deny rules for the most
; critical folders to prevent overlapping ALLOW rule exploitation
(deny file-read-data
    (subpath "/Users/mikkelmynderup/.ssh")
    (subpath "/Users/mikkelmynderup/.gnupg")
    (subpath "/Users/mikkelmynderup/Library/Keychains")
    (subpath "/Users/mikkelmynderup/.aws")
)

