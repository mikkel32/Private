(version 1)
(deny default)
(import "system.sb") ; Provides dyld shared cache access and base OS structures

; ==============================================================================
; PROJECT MONOLITH - macOS App Sandbox Profile (sandbox-exec)
; Target: Python Inference Engine (llama.cpp / FastAPI)
; ==============================================================================
; MITIGATION: Agentic Autonomy, Remote Code Execution (RCE), Data Exfiltration.
; 
; This strict policy enforces absolute isolation on the LLM instance to ensure
; a hijacked RAG or Prompt-Injection attack cannot compromise the host OS.
; It utilizes a STRICT DEFAULT-DENY model, effectively blocking all files,
; memory mapping, IPC, and network capabilities not overtly permitted.
; ==============================================================================

; Restricted RCE Binary Execution Array (Zero-Trust Branching)
(allow process-exec 
    (literal (string-append (param "PROJECT_DIR") "/sep_crypto"))
    (subpath (string-append (param "VENV_DIR") "/bin"))
    (subpath "/opt/homebrew/Cellar")
)
(allow process-fork)
(allow sysctl-read)
; Metal & CoreFoundation require specific Mach services. Enumerated instead of wildcard.
(allow mach-lookup
    (global-name "com.apple.CoreServices.coreservicesd")
    (global-name "com.apple.system.opendirectoryd.libinfo")
    (global-name "com.apple.system.notification_center")
    (global-name "com.apple.lsd.mapdb")
    (global-name "com.apple.gpumemd.source")
    (global-name "com.apple.fonts")
    (global-name "com.apple.trustd")
    (global-name "com.apple.cfprefsd.daemon")
    (global-name "com.apple.cfprefsd.agent")
    (global-name-regex #"^com\\.apple\\.metal")
    (global-name-regex #"^com\\.apple\\.iogpu")
    (global-name-regex #"^com\\.apple\\.AGX")
)

; --- EXPLICIT EXFILTRATION C&C NULLIFICATIONS ---
; Explictly destroy pathways attempting to escape sandbox constraints or spy generically.
(deny mach-lookup (global-name "com.apple.SecurityServer"))
(deny mach-lookup (global-name "com.apple.analyticsd"))
(deny mach-lookup (global-name "com.apple.diagnosticd"))
(deny mach-lookup (global-name "com.apple.syslogd"))
(deny mach-lookup (global-name "com.apple.system.logger"))
(deny mach-lookup (global-name "com.apple.windowserver.active"))
(deny mach-lookup (global-name "com.apple.awdd"))
(deny mach-lookup (global-name "com.apple.CoreLocation.agent"))

; P8-5 REMEDIATION: Scope iokit-open to Metal/GPU drivers ONLY.
; The blanket (allow iokit-open) let the LLM connect to ANY IOKit driver.
(allow iokit-open
    (iokit-user-client-class "AGXDeviceUserClient")
    (iokit-user-client-class "IOGPUDeviceUserClient")
    (iokit-user-client-class "AppleANEUserClient")
    (iokit-user-client-class "IOSurfaceRootUserClient")
    (iokit-user-client-class "IGAccelDevice")
    (iokit-user-client-class "IGAccelSharedUserClient")
    (iokit-user-client-class "IGAccelCommandQueue")
)
(allow signal)

; --- NETWORK ISOLATION ---
; Deny ALL outbound network connections to prevent exfiltration and C&C callbacks.
; (Deny default implicitly blocks this, but explicitly stated for semantic integrity)
(deny network-outbound (remote tcp))
(deny network-outbound (remote udp))
(deny network-outbound (remote ip))

; Explicit block of UNIX sockets to prevent mDNSResponder & syslog exfiltration
(deny network-outbound (remote unix-socket))

; Explicitly allow localhost bindings so the UI can communicate with the inference node
(allow network-inbound)
(allow network-bind)

; --- FILE SYSTEM ISOLATION ---
(allow file-read-metadata) ; Needed for python to resolve stat() and dtags

; Whitelisted READ access (Strict Minimum for Python & Metal Execution)
(allow file-read-data
    (subpath "/System/Library/Frameworks")
    (subpath "/System/Library/PrivateFrameworks")
    (subpath "/usr/lib")
    (subpath "/usr/share/zoneinfo")
    (subpath "/opt/homebrew/opt")
    (subpath "/opt/homebrew/Cellar")
    (subpath (param "VENV_DIR"))
    (subpath (param "PROJECT_DIR"))
    (literal (string-append (param "PROJECT_DIR") "/gemma-4-E4B-it-heretic-Q5_K_M.gguf"))
    (subpath (string-append (param "PROJECT_DIR") "/node_modules/llama-cpp-python"))
    ; P21-7 REMEDIATION: Use HOME_DIR param instead of hardcoded username.
    (subpath (string-append (param "HOME_DIR") "/Library/Caches"))
    (subpath "/private/var/folders")
    (subpath "/private/tmp")
    (literal "/dev/urandom")
    (literal "/dev/random")
    (literal "/dev/null")
)

; Allow writing ONLY to essential transient locations required by Python & macOS Metal.
(allow file-write* 
    (subpath "/private/tmp")
    (subpath "/private/var/folders")
    (subpath (string-append (param "PROJECT_DIR") "/__pycache__"))
    (literal "/dev/null")
    (literal "/dev/random")
    (literal "/dev/urandom")
)

; --- EXPLICIT DATA THEFT ISOLATION ---
; Even though default deny blocks this, we add explicit deny rules for the most
; critical folders to prevent overlapping ALLOW rule exploitation
; P21-7 REMEDIATION: Use HOME_DIR param for all user-specific paths.
(deny file-read-data
    (subpath (string-append (param "HOME_DIR") "/.ssh"))
    (subpath (string-append (param "HOME_DIR") "/.gnupg"))
    (subpath (string-append (param "HOME_DIR") "/Library/Keychains"))
    (subpath (string-append (param "HOME_DIR") "/.aws"))
)

